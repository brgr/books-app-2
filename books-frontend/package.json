{
  "name": "books-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l ${PORT:-4173}",
    "heroku-postbuild": "npm run build",
    "typecheck": "vue-tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "idb": "^8.0.3",
    "serve": "^14.2.5",
    "sortablejs": "^1.15.2",
    "vue": "^3.5.22",
    "vue-router": "^4.6.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.1.0"
  }
}
